# ---------- Pharos testnet RPC -----------------------------------------
# Default public endpoint (override if you run your own node):
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_CHAIN_ID=688689

# ---------- Deployer key -----------------------------------------------
# 64-hex private key, with or without leading 0x. Fund it from the
# Pharos testnet faucet before running `npm run deploy:pharos`.
DEPLOYER_PRIVATE_KEY=

# ---------- Skill server -----------------------------------------------
PORT=8787
